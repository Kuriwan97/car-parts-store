<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Car Parts Store</display-name>
    <description>Online store for car parts</description>

    <!-- ==================== ФИЛЬТРЫ ==================== -->

    <!-- Фильтр авторизации -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.carparts.filter.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Фильтр кодировки -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>com.carparts.filter.CharacterEncodingFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== СЕРВЛЕТЫ ДЛЯ АВТОРИЗАЦИИ ==================== -->

    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.carparts.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.carparts.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.carparts.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- ==================== СЕРВЛЕТЫ ДЛЯ РАБОТЫ С ЗАПЧАСТЯМИ ==================== -->

    <!-- Parts Servlet (просмотр каталога) -->
    <servlet>
        <servlet-name>PartsServlet</servlet-name>
        <servlet-class>com.carparts.servlet.PartsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PartsServlet</servlet-name>
        <url-pattern>/parts</url-pattern>
    </servlet-mapping>

    <!-- Add Part Servlet (добавление) -->
    <servlet>
        <servlet-name>AddPartServlet</servlet-name>
        <servlet-class>com.carparts.servlet.AddPartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddPartServlet</servlet-name>
        <url-pattern>/addPart</url-pattern>
    </servlet-mapping>

    <!-- Edit Part Servlet (редактирование) -->
    <servlet>
        <servlet-name>EditPartServlet</servlet-name>
        <servlet-class>com.carparts.servlet.EditPartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditPartServlet</servlet-name>
        <url-pattern>/editPart</url-pattern>
    </servlet-mapping>

    <!-- Delete Part Servlet (удаление) -->
    <servlet>
        <servlet-name>DeletePartServlet</servlet-name>
        <servlet-class>com.carparts.servlet.DeletePartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeletePartServlet</servlet-name>
        <url-pattern>/deletePart</url-pattern>
    </servlet-mapping>

    <!-- ==================== СЕРВЛЕТЫ ДЛЯ ПОЛЬЗОВАТЕЛЯ ==================== -->

    <!-- User Profile Servlet (профиль пользователя) -->
    <servlet>
        <servlet-name>UserProfileServlet</servlet-name>
        <servlet-class>com.carparts.servlet.UserProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserProfileServlet</servlet-name>
        <url-pattern>/profile</url-pattern>
    </servlet-mapping>

    <!-- ==================== НАСТРОЙКИ ==================== -->

    <!-- Главная страница -->
    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>

    <!-- Настройки сессии (таймаут в минутах) -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Настройки JSP -->
    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <page-encoding>UTF-8</page-encoding>
            <default-content-type>text/html;charset=UTF-8</default-content-type>
        </jsp-property-group>
    </jsp-config>

    <!-- Обработка ошибок -->
    <error-page>
        <error-code>404</error-code>
        <location>/login.html</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/login.html</location>
    </error-page>
</web-app>